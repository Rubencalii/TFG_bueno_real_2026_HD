{% extends 'base.html.twig' %}

{% block title %}Inicio - Comanda Digital{% endblock %}

{% block body %}
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2463eb",
                        "background-light": "#f6f6f8",
                        "background-dark": "#111621",
                    },
                },
            },
        }
    </script>
    
    <!-- Top Navigation Bar -->
    <header class="w-full flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark px-10 py-4 shadow-sm">
        <div class="flex items-center gap-3 text-slate-900 dark:text-white">
            <div class="w-8 h-8 text-primary">
                <span class="material-symbols-outlined text-3xl">restaurant_menu</span>
            </div>
            <h1 class="text-xl font-bold leading-tight tracking-tight">Comanda Digital</h1>
        </div>
        <div class="flex gap-4">
            {% if app.user %}
                <span class="text-slate-600 dark:text-slate-300 font-medium self-center">Hola, {{ app.user.email }}</span>
                <a href="{{ path('logout') }}" class="px-4 py-2 bg-red-600 text-white rounded-lg font-medium hover:bg-red-700 transition-colors shadow">Cerrar Sesión</a>
            {% else %}
                <a href="{{ path('login') }}" class="px-4 py-2 bg-primary text-white rounded-lg font-medium hover:bg-blue-700 transition-colors shadow">Iniciar Sesión</a>
            {% endif %}
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col items-center justify-center p-6 mt-16">
        <div class="w-full max-w-4xl text-center">
            <h2 class="text-5xl font-extrabold text-slate-900 dark:text-white mb-6">Gestiona tus comandas de forma moderna</h2>
            <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 max-w-2xl mx-auto">Nuestro sistema de Gestión de Comandas y Restaurante digitaliza la toma de pedidos, conexión entre barra y cocina de manera eficiente y ágil.</p>
            
            <div class="flex justify-center gap-4">
                {% if app.user %}
                    <a href="{{ path('login') }}" class="px-8 py-4 bg-primary text-white text-lg rounded-xl font-bold hover:bg-blue-700 transition-all shadow-lg hover:shadow-xl">Ir a mi Panel</a>
                {% else %}
                    <a href="{{ path('login') }}" class="px-8 py-4 bg-primary text-white text-lg rounded-xl font-bold hover:bg-blue-700 transition-all shadow-lg hover:shadow-xl">Iniciar Sesión</a>
                {% endif %}
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-24 w-full max-w-5xl pb-12">
            <!-- Feature 1 -->
            <div class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 flex flex-col items-center text-center">
                <div class="size-16 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 flex items-center justify-center rounded-2xl mb-4">
                    <span class="material-symbols-outlined text-4xl">inventory</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Pedidos Ágiles</h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm">Registro de comandas de manera rápida con interfaz optimizada.</p>
            </div>
            
            <!-- Feature 2 -->
            <div class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 flex flex-col items-center text-center">
                <div class="size-16 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 flex items-center justify-center rounded-2xl mb-4">
                    <span class="material-symbols-outlined text-4xl">kitchen</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Conexión Directa</h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm">Enlace directo con cocina o barra, sin intermediarios, optimizando el tiempo.</p>
            </div>
            
            <!-- Feature 3 -->
            <div class="bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 flex flex-col items-center text-center">
                <div class="size-16 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 flex items-center justify-center rounded-2xl mb-4">
                    <span class="material-symbols-outlined text-4xl">devices</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Multi-Dispositivo</h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm">Acceso desde cualquier dispositivo móvil, terminal punto de venta o pantalla.</p>
            </div>
        </div>
    </main>
{% endblock %}
